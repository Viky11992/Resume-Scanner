# PostgreSQL Database Configuration
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resume_screener

# Connection Pool Settings (optional)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# AI API Keys for interview question generation

# Option 1: Google Gemini API (FREE - Recommended)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Option 2: OpenAI API Key (Paid)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-api-key-here

# Option 3: Groq API (FREE - Default for question generation)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Authentication & Security
# Generate a secure random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-secret-key-change-this-in-production
